# Copy this file to .env for local private configuration.
# Do not commit real credentials or private source paths.

# Tableau connector adapter. Required only when running live Tableau sync/export.
TABLEAU_BASE_URL=
TABLEAU_SITE_ID=
TABLEAU_PAT_NAME=
TABLEAU_PAT_SECRET=

# Optional workspace override for scripts launched outside the repository root.
ANALYST_WORKSPACE_DIR=
